---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thanks - Denver AI"
  description="We'll be in touch shortly to set up your free call."
  canonicalPath="/thank-you"
>
  <div class="thank-you">
    <div class="inner">
      <div class="icon">✓</div>
      <h1>You're on the list.</h1>
      <p>We'll reach out shortly to set up your free call. In the meantime, feel free to look around.</p>
      <a href="/" class="back-btn">Back to DenverAI</a>
    </div>
  </div>
</Layout>

<style>
  .thank-you {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1C1C1E;
    padding: 2rem;
  }

  .inner {
    text-align: center;
    max-width: 480px;
  }

  .icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FF6B35;
    color: #fff;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }

  p {
    font-size: 1rem;
    color: #888;
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .back-btn {
    display: inline-block;
    background: transparent;
    color: #FF6B35;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.6rem 1.4rem;
    border-radius: 50px;
    border: 1.5px solid #FF6B35;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .back-btn:hover {
    background: #FF6B35;
    color: #fff;
  }
</style>
