---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout
  title="Blog | Denver AI - AI for Colorado Small Businesses"
  description="Practical takes on AI for Denver-area small businesses. What works, what doesn't, and how to get started without the hype."
  canonicalPath="/blog"
>
  <div class="blog-index">
    <div class="container">
      <header class="blog-header">
        <a href="/" class="back-link">← Denver AI</a>
        <h1>AI for Colorado businesses</h1>
        <p>Practical takes on what's actually working - no hype, no jargon.</p>
      </header>
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`/blog/${post.slug}`} class="post-link">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Layout>

<style>
  .blog-index {
    padding: 6rem 2rem 4rem;
    min-height: 100vh;
    background: #F5F5F3;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #FF6B35;
  }

  .blog-header h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: #1C1C1E;
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
  }

  .blog-header p {
    font-size: 1rem;
    color: #888;
    margin: 0 0 3rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid #E8E8E5;
  }

  .post-item {
    border-bottom: 1px solid #E8E8E5;
  }

  .post-link {
    display: block;
    padding: 1.75rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.2s;
  }

  .post-link:hover {
    padding-left: 0.5rem;
  }

  .post-link time {
    display: block;
    font-size: 0.8rem;
    color: #aaa;
    margin-bottom: 0.4rem;
    letter-spacing: 0.04em;
  }

  .post-link h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #1C1C1E;
    letter-spacing: -0.02em;
    margin: 0 0 0.4rem;
    line-height: 1.3;
    transition: color 0.15s;
  }

  .post-link:hover h2 {
    color: #FF6B35;
  }

  .post-link p {
    font-size: 0.9rem;
    color: #888;
    margin: 0;
    line-height: 1.6;
  }
</style>
