---
const outcomes = [
  {
    title: "Streamline admin work",
    bullets: [
      "Invoices and quotes sent automatically",
      "Scheduling handled without back-and-forth",
      "Less time on paperwork, more time on the job",
    ],
    color: "#FF6B35",
  },
  {
    title: "Automate follow-through",
    bullets: [
      "Follow-up texts and emails sent automatically",
      "Reminders go out without you remembering to send them",
      "Jobs keep moving without constant chasing",
    ],
    color: "#FF4D6D",
  },
  {
    title: "Stay responsive",
    bullets: [
      "New leads get a reply before they move on",
      "Customers get clear updates without you writing them",
      "Handle more volume without adding staff",
    ],
    color: "#FFD60A",
  },
  {
    title: "Capture every lead",
    bullets: [
      "Respond to leads even when you're on a job",
      "First to reply usually wins the job",
      "Nothing falls through after hours",
    ],
    color: "#4ADE80",
  },
];
---

<section class="outcomes">
  <div class="outcomes-inner">
    <h2>What we do with AI.</h2>
    <div class="outcomes-grid">
      {outcomes.map((o) => (
        <div class="outcome-card" style={`border-left: 4px solid ${o.color};`}>
          <h3>{o.title}</h3>
          <ul>
            {o.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .outcomes {
    padding: 5rem 0;
    background: #ffffff;
  }

  .outcomes-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .overline {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #999;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #1C1C1E;
    letter-spacing: -0.02em;
    margin: 0 0 3rem;
  }

  .outcomes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .outcomes-grid {
      grid-template-columns: 1fr;
    }
  }

  .outcome-card {
    background: #FEF9E0;
    border-radius: 16px;
    padding: 2rem;
  }

  h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1C1C1E;
    margin: 0 0 1rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  li {
    font-size: 0.9rem;
    line-height: 1.5;
    color: #666;
    padding-left: 1.1rem;
    position: relative;
  }

  li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #E8E8E5;
  }
</style>
