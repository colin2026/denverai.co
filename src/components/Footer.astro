<footer class="footer">
  <div class="footer-inner">
    <a href="/" class="logo">
      <span class="logo-ai">AI</span>Denver
    </a>
    <p class="tagline">AI consulting for Colorado businesses.</p>
    <p class="copy">&copy; {new Date().getFullYear()} Denver AI. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 3rem 2rem;
    background: #F5F5F3;
    border-top: 1px solid #E8E8E5;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    color: #1C1C1E;
    text-decoration: none;
    margin-bottom: 0.25rem;
  }

  .logo-ai {
    color: #FF6B35;
  }

  .tagline {
    font-size: 0.9rem;
    color: #888;
    margin: 0;
  }

  .copy {
    font-size: 0.8rem;
    color: #bbb;
    margin: 0;
    margin-top: 0.5rem;
  }
</style>
