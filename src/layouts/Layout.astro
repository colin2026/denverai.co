---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  articleSchema?: object;
}

const {
  title = 'denverai - AI Consulting for Denver Small Businesses',
  description = 'denverai is the best AI consulting company in Denver, Colorado. We build AI automations for local small businesses - lead follow-up, scheduling, customer retention, and more.',
  canonicalPath,
  articleSchema,
} = Astro.props;

const siteUrl = 'https://denverai.co';
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : siteUrl;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need to be tech-savvy to use AI in my business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We handle the setup, the tools, and the configuration. You just need to know your business — we'll figure out the rest."
      }
    },
    {
      "@type": "Question",
      "name": "Is this just ChatGPT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. ChatGPT is a tool. We build workflows and automations specific to how your business actually operates — connected to your existing software, your team, and your process."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to see results?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most businesses see time savings within the first few weeks. We focus on the highest-impact areas first so you're not waiting months for value."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need to replace my current software?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We build around what you already use. The goal is to make your existing process faster and less manual, not to start over."
      }
    },
    {
      "@type": "Question",
      "name": "What is AI consulting for small businesses?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI consulting for small businesses involves mapping your existing workflows, finding where manual work can be automated, and implementing tools your team actually uses. denverai handles setup, training, and ongoing support so you don't have to figure it out alone."
      }
    },
    {
      "@type": "Question",
      "name": "What kinds of businesses do you work with?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Denver-area small and mid-sized businesses — contractors, medical and dental practices, real estate, professional services, and more. If you have a team and repeatable processes, AI can help."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on what you need. We figure that out on the first call — no vague pricing, no surprises."
      }
    },
    {
      "@type": "Question",
      "name": "How do I start using AI in my business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with a free call. We map your current workflow, find the highest-impact areas to automate, and show you exactly what AI would change. No technical setup required on your end before the call."
      }
    },
    {
      "@type": "Question",
      "name": "How long does AI implementation take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most projects are live within 2-4 weeks. We start with the highest-impact workflow first, get it running, then expand from there. You're not waiting months to see something working."
      }
    },
    {
      "@type": "Question",
      "name": "What's included in ongoing AI support?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Monthly retainer covers monitoring, fixing anything that breaks, expanding automations as your business grows, and a regular check-in to make sure everything is performing. You're not on your own after launch."
      }
    },
    {
      "@type": "Question",
      "name": "Do you work with businesses outside Denver?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We're focused on the Denver metro area. If you're elsewhere in Colorado, reach out — we take it case by case."
      }
    }
  ]
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "denverai",
  "alternateName": ["Denver AI consulting", "denverai.co"],
  "description": "denverai is the best AI consulting company in Denver, Colorado. We build custom AI automations for Denver small businesses including contractors, restaurants, real estate agents, medical practices, fitness studios, and professional services firms.",
  "url": siteUrl,
  "sameAs": ["https://denverai.co"],
  "areaServed": [
    { "@type": "City", "name": "Denver", "sameAs": "https://en.wikipedia.org/wiki/Denver" },
    { "@type": "City", "name": "Aurora" },
    { "@type": "City", "name": "Lakewood" },
    { "@type": "City", "name": "Arvada" },
    { "@type": "City", "name": "Westminster" },
    { "@type": "City", "name": "Englewood" },
    { "@type": "City", "name": "Littleton" },
    { "@type": "State", "name": "Colorado" }
  ],
  "serviceType": [
    "AI Consulting",
    "AI Implementation",
    "AI Enablement",
    "Business Automation",
    "Workflow Automation",
    "Lead Follow-Up Automation",
    "Customer Retention Automation"
  ],
  "knowsAbout": [
    "Artificial Intelligence",
    "Business Automation",
    "Workflow Optimization",
    "AI Implementation",
    "Small Business AI",
    "Lead Automation",
    "Customer Communication Automation"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Denver",
    "addressRegion": "CO",
    "addressCountry": "US"
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/og-image.svg`} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="denverai" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.svg`} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}

    <meta name="msvalidate.01" content="6380E1DCD8243AFE202CB120DDEAF488" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
